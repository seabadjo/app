# Serveur
NODE_ENV=development
PORT=5000

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aycm_db
DB_USER=postgres
DB_PASSWORD=postgres
# Alternative : URL complète (prioritaire si fournie)
# DATABASE_URL=postgres://user:password@host:5432/aycm_db

# JWT
JWT_SECRET=remplace_moi_par_une_cle_secrete_longue
JWT_EXPIRES_IN=7d

# CORS (URL du frontend)
CLIENT_URL=http://localhost:3000

# SMTP (formulaire de contact + newsletter)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="AYCM <no-reply@aycm.org>"
MAIL_TO=contact@aycm.org

# Paiements (dons / adhésions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
